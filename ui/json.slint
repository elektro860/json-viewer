import { JsonUtils } from "JsonUtils.slint";
export enum ValueType {
  null,
  number,
  bool,
  string,
  array,
  object,
}
export struct JsonValue {
  name: string,
  value: string,
  level: int,
  value_type: ValueType,
  id: int,

  // Flags
  in_filter: bool,
  has_key: bool,
}

export component JsonRow inherits Rectangle {
    in property <JsonValue> value;

    property <bool> is-array: value.value == "{" || value.value == "[";
    property <length> indent:value.level * 10px;
    height: 30px;
    width: 100%;

    background: value.in-filter ? #933 : #333;
    VerticalLayout {
        spacing: 0;
        HorizontalLayout {
            padding-left: indent;
            alignment: start;

            if value.has-key: Rectangle {
                min-width: 1rem;
                border-color: #bbb;
                border-width: 1px;

                TextInput {
                    text: value.name;
                    input-type: text;
                    width: 100%;

                    accepted => {
                        let valid = JsonUtils.set-key(value.id, self.text);
                        if !valid {
                            self.text = value.name;
                        }
                    }
                    edited => {
                        let valid = JsonUtils.is-valid-json-key(self.text);
                        parent.background = valid ? #333 : #c33;
                    }
                }
            }
            if !value.has-key: Rectangle {
                min-width: 1rem;

                Text {
                    text: value.name;
                    width: 100%;
                }
            }

            if value.name != "": Text {
                text: ": ";
            }
            if is-array: Text {
                text: value.value;
            }

            if !is-array: Rectangle {
                min-width: 1rem;
                border-color: #bbb;
                border-width: 1px;

                TextInput {
                    text: value.value;
                    input-type: text;
                    width: parent.width;

                    accepted => {
                        let valid = JsonUtils.set-value(value.id, self.text);
                        if !valid {
                            self.text = value.name;
                        }
                    }
                    edited => {
                        let valid = JsonUtils.is-valid-json-value(self.text);
                        parent.background = valid ? #333 : #c33;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #222;
        }

        // ta := TouchArea { }
    //
    // states [
    //     hover when ta.has-hover: {
    //         background: #555;
    //     }
    // ]
    }
}
